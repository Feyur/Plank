# Скопируй в .env и заполни значениями. Сам .env в git не попадает.

# Postgres
POSTGRES_USER=plank
POSTGRES_PASSWORD=
POSTGRES_DB=plank
# Для API на хосте (dev): контейнер проброшен на 127.0.0.1:5433.
# Для API внутри docker-сети (прод) адрес будет postgres://plank:...@db:5432/plank
DATABASE_URL=postgres://plank:@127.0.0.1:5433/plank

# API
API_PORT=3000
# Секрет для подписи сессий/JWT (сгенерируй: openssl rand -hex 32)
AUTH_SECRET=
# Аккаунты, которым доступно создание пользователей и назначение досок.
ACCESS_ADMIN_EMAILS=admin@example.com
# На production регистрация закрыта по умолчанию; аккаунты создаёт администратор.
REGISTRATION_ENABLED=true

# Frontend
VITE_API_URL=http://localhost:3000
