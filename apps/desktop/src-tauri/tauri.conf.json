{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Plank",
  "version": "0.1.0",
  "identifier": "ru.atank.plank",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Plank",
        "url": "https://plank.atank.ru:9443/",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
