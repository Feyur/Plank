# Прод-окружение для docker-compose.prod.yml. Скопируй в .env.prod и заполни.
# .env.prod с реальными секретами в git НЕ коммитим.

# Postgres (внутренняя сеть)
POSTGRES_USER=plank
POSTGRES_PASSWORD=
POSTGRES_DB=plank
DATABASE_URL=postgres://plank:@db:5432/plank

# Секрет подписи сессий: openssl rand -hex 32
AUTH_SECRET=

# Аккаунты, которым доступно создание пользователей и назначение досок.
ACCESS_ADMIN_EMAILS=admin@example.com

# Secure-cookie: true при HTTPS, false для доступа по http (превью по IP).
COOKIE_SECURE=true

# Порт HTTPS у Caddy (должен совпадать с https_port в Caddyfile).
# 443 стандартный; если занят — свободный, напр. 9443.
HTTPS_PORT=9443

# Открытая регистрация. На публичном сервере — false, аккаунты заводит админ.
REGISTRATION_ENABLED=false

# Origin фронта (для CORS; при same-origin можно указать сам адрес сервера).
WEB_ORIGIN=http://SERVER_IP

# Стартовые аккаунты: "email:пароль:Имя;email2:пароль2:Имя2"
SEED_USERS=
